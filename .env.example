# Docker Compose Environment Variables
# Copy this file to .env and customize for your environment

# Service Configuration
PORTFOLIO_PORT=80
COMPOSE_PROJECT_NAME=portfolio

# Timezone
TIMEZONE=UTC

# Logging
LOG_LEVEL=info

# Node Environment
NODE_ENV=production

# Optional: Resource limits (for compose production files)
CPU_LIMIT=1
CPU_RESERVATION=0.5
MEMORY_LIMIT=512M
MEMORY_RESERVATION=256M
